```gitignore
# ===============================
# 🔐 Environment & Secrets
# ===============================
.env
.env.*
*.env

# ===============================
# 🐍 Python
# ===============================
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# ===============================
# 📦 Packaging
# ===============================
build/
dist/
*.egg-info/
.eggs/

# ===============================
# 🧪 Testing & Coverage
# ===============================
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# ===============================
# 📊 Jupyter Notebook
# ===============================
.ipynb_checkpoints/

# ===============================
# ⚙️ IDE / Editor Files
# ===============================
.vscode/
.idea/
*.swp
*.swo

# ===============================
# 🧠 ML / RAG Artifacts
# ===============================
*.model
*.pkl
*.joblib
*.h5
*.pt
*.bin

# Vector DB / embeddings
chroma/
qdrant_storage/
faiss_index/

# ===============================
# 📂 Logs
# ===============================
logs/
*.log

# ===============================
# 🖼️ OS Files
# ===============================
.DS_Store
Thumbs.db

# ===============================
# 🚀 FastAPI / Server
# ===============================
*.db
*.sqlite3

# ===============================
# 🔥 Temporary Files
# ===============================
tmp/
temp/
*.tmp
```
